# ===========================================
# AI-Powered Remote IT Support Platform
# Environment Configuration
# ===========================================

# Server
NODE_ENV=production
PORT=4000
FRONTEND_URL=http://localhost:5173

# Database - PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_it_support
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4

# Apache Guacamole
GUACAMOLE_URL=http://localhost:8080/guacamole
GUACAMOLE_SECRET=your_guacamole_secret

# Agent
AGENT_SECRET=your_agent_registration_secret
HEARTBEAT_INTERVAL=30000

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Encryption
ENCRYPTION_KEY=your_32_char_encryption_key_here

# Coolify Deployment
COOLIFY_URL=http://187.127.134.246:8000
